---
import Footer from '../../components/Footer.astro';
import { CategoryPill } from '../../components/CategoryPill';
import { Sources } from '../../components/Sources';
import { StatusBadge } from '../../components/StatusBadge';
import Base from '../../layouts/Base.astro';
import { formatExaflops, formatYearMonth } from '../../lib/format';
import { loadFacilities } from '../../lib/load-facilities';

export async function getStaticPaths() {
  const facilities = await loadFacilities();

  return facilities.map((facility) => ({
    params: { slug: facility.slug },
    props: { facility },
  }));
}

const { facility } = Astro.props;
---

<Base description={facility.oneLiner} title={`${facility.name} | UK Public-Sector AI Compute`}>
  <article class="mx-auto max-w-4xl px-6 py-14">
    <a class="text-sm text-stone-600 underline decoration-stone-400 underline-offset-4 transition hover:text-ink hover:decoration-ink" href="/">
      Back to map
    </a>

    <header class="mt-6 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">
        Facility profile
      </p>
      <h1 class="mt-3 font-serif text-4xl">{facility.name}</h1>
      <p class="mt-3 text-base text-stone-700">
        {facility.location.institution}, {facility.location.city}, {facility.location.nation}
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <CategoryPill category={facility.category} />
        <StatusBadge status={facility.status} />
      </div>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-stone-800">{facility.oneLiner}</p>
    </header>

    <section class="mt-8 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <h2 class="font-serif text-2xl">At a glance</h2>
      <dl class="mt-5 grid gap-4 sm:grid-cols-2">
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Hardware</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{facility.keyFacts.hardware}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Performance</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{facility.keyFacts.performance}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">AI-exaflops</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{formatExaflops(facility.aiExaflops)}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Funding</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{facility.keyFacts.funding}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Energy</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{facility.keyFacts.energy}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Operator</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{facility.operator}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Funder</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{facility.funder}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Opened</dt>
          <dd class="mt-2 text-sm leading-relaxed text-stone-800">{formatYearMonth(facility.opened)}</dd>
        </div>
      </dl>
    </section>

    <section class="mt-8 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <h2 class="font-serif text-2xl">Overview</h2>
      <p class="mt-4 leading-relaxed text-stone-700">{facility.summary}</p>
    </section>

    <section class="mt-8 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <h2 class="font-serif text-2xl">Hardware & performance</h2>
      <div class="mt-5 overflow-x-auto">
        <table class="w-full border-collapse text-left text-sm text-stone-700">
          <tbody>
            <tr class="border-b border-stone-200">
              <th class="py-3 pr-4 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Hardware</th>
              <td class="py-3 leading-relaxed">{facility.keyFacts.hardware}</td>
            </tr>
            <tr class="border-b border-stone-200">
              <th class="py-3 pr-4 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Performance</th>
              <td class="py-3 leading-relaxed">{facility.keyFacts.performance}</td>
            </tr>
            <tr class="border-b border-stone-200">
              <th class="py-3 pr-4 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">AI-exaflops</th>
              <td class="py-3 leading-relaxed">{formatExaflops(facility.aiExaflops)}</td>
            </tr>
            <tr class="border-b border-stone-200">
              <th class="py-3 pr-4 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Energy</th>
              <td class="py-3 leading-relaxed">{facility.keyFacts.energy}</td>
            </tr>
            <tr>
              <th class="py-3 pr-4 text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500">Hardware tags</th>
              <td class="py-3 leading-relaxed">{facility.hardwareTags.join(', ')}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <h2 class="font-serif text-2xl">Access & eligibility</h2>
      <p class="mt-4 leading-relaxed text-stone-700">{facility.access.route}</p>
      <p class="mt-3 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">
        Access type: {facility.access.accessType}
      </p>
      {facility.federationMembers ? (
        <div class="mt-5">
          <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">
            Federation members
          </h3>
          <ul class="mt-3 space-y-2 text-sm text-stone-700">
            {facility.federationMembers.map((member) => (
              <li>{member}</li>
            ))}
          </ul>
        </div>
      ) : null}
    </section>

    <section class="mt-8 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <h2 class="font-serif text-2xl">Use cases</h2>
      <ul class="mt-4 space-y-2 text-sm text-stone-700">
        {facility.useCases.map((useCase) => (
          <li class="flex gap-2">
            <span class="mt-[0.45rem] h-1.5 w-1.5 rounded-full bg-stone-500"></span>
            <span>{useCase}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-8 rounded-[2rem] border border-stone-300 bg-white p-6 shadow-[0_28px_60px_-40px_rgba(20,20,20,0.5)]">
      <h2 class="font-serif text-2xl">Sources</h2>
      <div class="mt-4">
        <Sources sources={facility.sources} />
      </div>
    </section>
  </article>
  <Footer />
</Base>
